# Stage 2 Claude Code 配置示例
# 复制到 /etc/companion/claude-code.env 后修改。

# 后续 Bridge 必须用同一个 Linux 用户启动 Claude Code，否则读不到登录态。
# root 登录 VPS 就保持 root；如果你用 ubuntu/han/companion 等用户登录，就改成对应用户名。
CLAUDE_RUN_USER="root"

# companion-claude 是之后 Bridge 调用 Claude Code 的工作目录。
COMPANION_CLAUDE_DIR="/opt/companion/claude"

# Claude Code 用户级配置目录。以哪个 Linux 用户运行 Claude，就指向哪个用户的 home。
CLAUDE_HOME="/root/.claude"

# 人格提示文件会安装到 ${CLAUDE_HOME}/CLAUDE.md。
CLAUDE_USER_PROMPT_PATH="/root/.claude/CLAUDE.md"

# 默认加载项目级 MCP 配置。HTTP 模式对应 config/mcp.http.json.example。
MCP_CONFIG_PATH="/opt/companion/claude/.mcp.json"

# Ombre Brain MCP transport：http 或 stdio。
OMBRE_TRANSPORT="http"

# HTTP 模式：Stage 1 暴露的 MCP endpoint。
OMBRE_MCP_HTTP_URL="http://127.0.0.1:8765/mcp"

# 如果 Ombre Brain HTTP endpoint 需要静态鉴权 header，在这里填。
# 例如：OMBRE_MCP_AUTH_HEADER_NAME="Authorization"; OMBRE_MCP_AUTH_HEADER_VALUE="Bearer xxx"
OMBRE_MCP_AUTH_HEADER_NAME=""
OMBRE_MCP_AUTH_HEADER_VALUE=""

# stdio 模式：Stage 1 官方启动命令。
OMBRE_APP_DIR="/opt/companion/ombre-brain/app"
OMBRE_STDIO_COMMAND="npm"
OMBRE_STDIO_ARGS="start"

# Claude Code 安装通道：stable 或 latest。服务器建议 stable。
CLAUDE_CODE_CHANNEL="stable"

# 启动参数。Bridge 用 node-pty 常驻时建议 interactive。
# interactive：启动可交互 Claude Code，stdin/stdout 由 PTY 控制。
# print：单次输入单次输出，适合 smoke test。
CLAUDE_START_MODE="interactive"

# 是否让 Claude Code 使用更详细的 stream 信息；Bridge 后面会解析 thinking/tool_use。
CLAUDE_VERBOSE="1"

# 默认会话名，便于后续 resume / 日志识别。
CLAUDE_SESSION_NAME="companion-claude"
