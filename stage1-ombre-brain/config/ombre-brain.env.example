# Ombre Brain Stage 1 配置示例
# 复制到 /etc/companion/ombre-brain.env 后，把占位项改成官方仓库文档给出的值。

# 必填：Ombre Brain 官方仓库 URL。
OMBRE_REPO_URL="https://github.com/OWNER/ombre-brain.git"

# 可选：官方文档推荐的 tag/branch/commit。生产环境建议固定到 tag 或 commit。
OMBRE_REPO_REF="main"

# 部署位置。脚本会把仓库 clone 到 OMBRE_APP_DIR。
OMBRE_APP_DIR="/opt/companion/ombre-brain/app"
OMBRE_DATA_DIR="/var/lib/companion/ombre-brain"
OMBRE_LOG_DIR="/var/log/companion"

# 运行身份。安装脚本会创建这个系统用户。
OMBRE_USER="companion"
OMBRE_GROUP="companion"

# 官方文档要求的安装命令。
# 示例：
#   OMBRE_INSTALL_CMD="npm ci"
#   OMBRE_INSTALL_CMD="uv sync --frozen"
#   OMBRE_INSTALL_CMD="python3 -m venv .venv && . .venv/bin/activate && pip install -e ."
OMBRE_INSTALL_CMD="npm ci"

# 官方文档要求的启动命令。
# systemd 会在 OMBRE_APP_DIR 下执行该命令，并暴露 OMBRE_DATA_DIR 等环境变量。
# 示例：
#   OMBRE_START_CMD="npm start"
#   OMBRE_START_CMD="node dist/index.js --transport http --host 127.0.0.1 --port 8765 --data-dir /var/lib/companion/ombre-brain"
#   OMBRE_START_CMD=". .venv/bin/activate && python -m ombre_brain --stdio"
OMBRE_START_CMD="npm start"

# Ombre Brain 如果提供 HTTP MCP endpoint，就填 http。
# 如果只提供 stdio，就填 stdio，并配置 OMBRE_STDIO_COMMAND。
OMBRE_TRANSPORT="http"

# HTTP 模式：按官方文档填写 MCP endpoint。
OMBRE_HOST="127.0.0.1"
OMBRE_PORT="8765"
OMBRE_HEALTH_URL="http://127.0.0.1:8765/health"
OMBRE_MCP_HTTP_URL="http://127.0.0.1:8765/mcp"

# stdio 模式：本地 smoke test 使用。systemd 仍用 OMBRE_START_CMD 常驻服务。
OMBRE_STDIO_COMMAND="npm start"

# 可选：Ombre Brain 自身支持的额外环境变量，按官方文档补充。
NODE_ENV="production"
